  <structure renderas="article" xml:id="ha-maintenance-performing-tasks-cluster-nodes" xml:lang="en">
    <merge>
      <title>Performing maintenance tasks on cluster nodes</title>
      <revhistory xml:id="rh-ha-maintenance-performing-tasks-cluster-nodes">
        <revision><date>2026-04-24</date><!-- Change date after review -->
          <revdescription>
            <para>
              Initial version
