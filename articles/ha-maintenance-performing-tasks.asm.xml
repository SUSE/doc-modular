  <structure renderas="article" xml:id="ha-maintenance-performing-tasks-cluster-infra" xml:lang="en">
    <merge>
      <title>Performing maintenance tasks on cluster infrastructure</title>
      <revhistory xml:id="rh-ha-maintenance-performing-tasks-cluster-infra">
        <revision><date>2026-04-24</date><!-- Change date after review -->
          <revdescription>
            <para>
              Initial version
            </para>
          </revdescription>
        </revision>
      </revhistory>
      <meta name="maintainer" content="tahlia.richardson@suse.com" its:translate="no"/>
      <meta name="architecture">
        <phrase>&x86-64;</phrase>
        <phrase>&power;</phrase>
        <phrase>&zseries;</phrase>
      </meta>
      <meta name="productname" its:translate="no">
        <productname version="&productnumber;" os="sleha">&productname;</productname>
      </meta>
      <meta name="title" its:translate="yes">TODO</meta>
      <meta name="description" its:translate="yes">TODO</meta>
      <meta name="social-descr" its:translate="yes">TODO</meta>
      <meta name="category" its:translate="no">
        <phrase>Administration</phrase>
      </meta>
      <meta name="task" its:translate="no">
        <phrase>Administration</phrase>
        <phrase>Clustering</phrase>
        <phrase>High Availability</phrase>
        <phrase>Maintenance</phrase>
      </meta>
      <meta name="series" its:translate="no">Products &amp; Solutions</meta>
      <dm:docmanager xmlns:dm="urn:x-suse:ns:docmanager">
        <dm:bugtracker>
          <dm:url>https://bugzilla.suse.com/enter_bug.cgi</dm:url>
          <dm:component>Documentation</dm:component>
          <dm:product>SUSE Linux Enterprise High Availability &productnumber;</dm:product>
          <dm:assignee>tahlia.richardson@suse.com</dm:assignee>
       </dm:bugtracker>
        <dm:translation>yes</dm:translation>
      </dm:docmanager>
      <abstract>
      <variablelist>
        <varlistentry>
          <term>WHAT?</term>
          <listitem>
            <para>
              &ha; clusters require different preparation steps for different maintenance tasks.
              Use this workflow when making changes to the configuration of the cluster services,
              or to infrastructure used by the cluster services, such as storage or networking.
            </para>
          </listitem>
        </varlistentry>
        <varlistentry>
          <term>WHY?</term>
          <listitem>
            <para>
              You must protect the cluster and its resources before performing maintenance tasks
              or you risk unwanted side effects such as resource failure, unsynchronized CIBs,
              or even data loss.
            </para>
          </listitem>
        </varlistentry>
        <varlistentry>
          <term>EFFORT</term>
            <listitem>
              <para>
                Preparing the cluster for maintenance only takes a few minutes, but the length of
                the maintenance window depends on the tasks you need to perform. In this scenario,
                most resources don't require downtime, but &dlm; and &dlm;-dependent resources do.
                The resources won't be highly available during the maintenance window.
              </para>
            </listitem>
        </varlistentry>
        <varlistentry>
          <term>GOAL</term>
            <listitem>
              <para>
                Minimize risk and downtime while making changes to infrastructure that affects
                the whole cluster. This workflow involves putting the whole cluster into
                maintenance mode and stopping the cluster services on all nodes at once, but
                <emphasis>not</emphasis> rebooting any nodes.
              </para>
            </listitem>
        </varlistentry>
        <!--varlistentry>
          <term>REQUIREMENTS</term>
            <listitem>
              <itemizedlist>
                <listitem>
                  <para>
                    Can't think of any other than an existing &sleha; cluster, which is obvious
                  </para>
                </listitem>
              </itemizedlist>
            </listitem>
          </varlistentry-->
        </variablelist>
        <important role="compact">
          <para>
            If this isn't the workflow you need, see <xref linkend="ha-maintenance-other-workflows"/>
            to choose the right one.
          </para>
        </important>
      </abstract>
    </merge>
