  <structure renderas="article" xml:id="ha-resources-adding-constraints" xml:lang="en">
    <merge>
      <title>Adding Constraints to HA Cluster Resources</title>
      <revhistory xml:id="rh-ha-resources-adding-constraints">
        <revision><date>2026-04-17</date><!--Change date after review-->
          <revdescription>
            <para>
              Initial version
            </para>
          </revdescription>
        </revision>
      </revhistory>
      <meta name="maintainer" content="tahlia.richardson@suse.com" its:translate="no"/>
      <meta name="architecture">
        <phrase>&x86-64;</phrase>
        <phrase>&power;</phrase>
        <phrase>&zseries;</phrase>
      </meta>
      <meta name="productname" its:translate="no">
        <productname version="&productnumber;" os="sleha">&productname;</productname>
      </meta>
      <meta name="title" its:translate="yes">Adding HA Cluster Resource Constraints</meta>
      <meta name="description" its:translate="yes">How to add resource constraints to specify where and when resources can run</meta>
      <meta name="social-descr" its:translate="yes">Add constraints to restrict HA cluster resources</meta>
      <meta name="category" its:translate="no">
        <phrase>Administration</phrase>
      </meta>
      <meta name="task" its:translate="no">
        <phrase>Administration</phrase>
        <phrase>Clustering</phrase>
        <phrase>Configuration</phrase>
        <phrase>High Availability</phrase>
      </meta>
      <meta name="series" its:translate="no">Products &amp; Solutions</meta>
      <dm:docmanager xmlns:dm="urn:x-suse:ns:docmanager">
        <dm:bugtracker>
          <dm:url>https://bugzilla.suse.com/enter_bug.cgi</dm:url>
          <dm:component>Documentation</dm:component>
          <dm:product>
            <dm:product>SUSE Linux Enterprise High Availability 16.1</dm:product>
          </dm:product>
          <dm:assignee>tahlia.richardson@suse.com</dm:assignee>
       </dm:bugtracker>
        <dm:translation>yes</dm:translation>
      </dm:docmanager>
      <abstract>
      <variablelist>
        <varlistentry>
          <term>WHAT?</term>
          <listitem>
            <para>
              Resource constraints let you specify which nodes resources can run on, what order
              resources should start in, and which resources are dependent on one another.
            </para>
          </listitem>
        </varlistentry>
        <varlistentry>
          <term>WHY?</term>
          <listitem>
            <para>
              Cluster resources sometimes depend on other resources or on a particular node
              configuration. Therefore, they might need to run in a specific location or start
              in a specific order.
            </para>
          </listitem>
        </varlistentry>
        <varlistentry>
          <term>EFFORT</term>
            <listitem>
              <para>
                Adding a resource constraint usually only takes a few minutes, depending on
                the complexity.
              </para>
            </listitem>
        </varlistentry>
        <varlistentry>
          <term>GOAL</term>
            <listitem>
              <para>
                Add resource constraints to specify where and when &ha; cluster resources can run.
              </para>
            </listitem>
        </varlistentry>
        <varlistentry>
          <term>REQUIREMENTS</term>
            <listitem>
              <itemizedlist>
                <listitem>
                  <para>
                    An existing &sleha; cluster
                  </para>
                </listitem>
                <listitem>
                  <para>
                    Existing cluster resources
                  </para>
                </listitem>
              </itemizedlist>
            </listitem>
          </varlistentry>
        </variablelist>
        <para>
          If you still need to configure cluster resources, see
          <link xlink:href="https://documentation.suse.com/sle-ha/16.0/html/HA-resources-configuring/">
          <citetitle>Configuring HA Cluster Resources</citetitle></link>.
        </para>
      </abstract>
    </merge>
