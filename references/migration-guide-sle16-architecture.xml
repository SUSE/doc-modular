<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic
[
<!ENTITY % entities SYSTEM "../common/generic-entities.ent">
%entities;
]>
<topic xml:id="migration-guide-sle16-architecture"
       role="reference" xml:lang="en"
       xmlns="http://docbook.org/ns/docbook" version="5.2"
       xmlns:its="http://www.w3.org/2005/11/its"
       xmlns:xi="http://www.w3.org/2001/XInclude"
       xmlns:xlink="http://www.w3.org/1999/xlink"
       xmlns:trans="http://docbook.org/ns/transclusion">
    <info>
        <title>Minimum CPU architecture requirements</title>
        <meta name="maintainer" content="daria.vladykina@suse.com" its:translate="no"/>
        <abstract>
            <para>
                The minimum supported microarchitecture levels for &suselinux;&nbsp;16 have been raised for most platforms:
            </para>
        </abstract>
    </info>
    <table xml:id="tab-migration-sle16-cpu-architecture">
        <title>Minimum CPU architecture support for &suselinux; 16</title>
        <tgroup cols="3">
            <colspec colnum="1" colname="architecture" colwidth="1*"/>
            <colspec colnum="2" colname="sle16min" colwidth="1*"/>
            <colspec colnum="3" colname="notes" colwidth="2*"/>
            <thead>
                <row>
                    <entry>
                        <para>Architecture</para>
                    </entry>
                    <entry>
                        <para>&suselinux;&nbsp;16 Minimum</para>
                    </entry>
                    <entry>
                        <para>Notes for Version 16</para>
                    </entry>
                </row>
            </thead>
            <tbody>
                <row>
                    <entry>
                        <para>&x86-64; (x86-64)</para>
                    </entry>
                    <entry>
                        <para>x86-64-v2</para>
                    </entry>
                    <entry>
                        <para>Optimized v3 shared libraries are auto-installed where
                            supported. Package names include
                            <literal>x86-64-v3</literal>.</para>
                    </entry>
                </row>
                <row>
                    <entry>
                        <para>&ibm; &power; (&ppc64le;)</para>
                    </entry>
                    <entry>
                        <para>&power;10</para>
                    </entry>
                    <entry>
                        <para>While &suselinux;&nbsp;16 can run on &power;9, this configuration is not supported.</para>
                    </entry>
                </row>
                <row>
                    <entry>
                        <para>&zseries; (s390x)</para>
                    </entry>
                    <entry>
                        <para>z14</para>
                    </entry>
                    <entry>
                        <para/>
                    </entry>
                </row>
                <row>
                    <entry>
                        <para>&arm; (&aarch64;)</para>
                    </entry>
                    <entry>
                        <para>ARMv8.0-A</para>
                    </entry>
                    <entry>
                        <para>This requirement remains unchanged from &slea; 15.</para>
                    </entry>
                </row>
                <row>
                    <entry>
                        <para>Intel 32-bit</para>
                    </entry>
                    <entry>
                        <para>Not supported</para>
                    </entry>
                    <entry>
                        <para>32-bit system calls are available via
                            <package>grub2-compat-ia32</package> from &suse; Package
                            Hub.</para>
                    </entry>
                </row>
            </tbody>
        </tgroup>
    </table>
</topic>