    <info>
        <title>What are the minimum CPU architecture requirements?</title><!-- can be changed via merge in the assembly -->
        <!--add author's email address-->
        <meta name="maintainer" content="daria.vladykina@suse.com" its:translate="no"/>
        <abstract><!-- can be changed via merge in the assembly -->
            <para>
                The minimum supported microarchitecture levels have been raised for most platforms:
            </para>
        </abstract>
    </info>
       <table xml:id="tab-migration-sle16-cpu-architecture">
            <title>Minimum CPU architecture support per platform</title>
            <tgroup cols="4">
                <colspec colnum="1" colname="architecture"/>
                <colspec colnum="2" colname="sle15min"/>
                <colspec colnum="3" colname="sle16min"/>
                <colspec colnum="4" colname="notes"/>
                <thead>
                    <row>
                        <entry>
                            <para>Architecture</para>
                        </entry>
                        <entry>
                            <para>&slea; 15 minimum</para>
                        </entry>
                        <entry>
                            <para>&suselinux;&nbsp;16 minimum</para>
                        </entry>
                        <entry>
                            <para>Notes</para>
                        </entry>
                    </row>
                </thead>
                <tbody>
                    <row>
                        <entry>
                            <para>&x86-64; (x86-64)</para>
                        </entry>
                        <entry>
                            <para>x86-64-v1</para>
                        </entry>
                        <entry>
                            <para>x86-64-v2</para>
                        </entry>
                        <entry>
                            <para>Optimized v3 shared libraries are auto-installed where
                                supported. Package names include
                                <literal>x86-64-v3</literal>.</para>
                        </entry>
                    </row>
                    <row>
                        <entry>
                            <para>&ibm; &power; (&ppc64le;)</para>
                        </entry>
                        <entry>
                            <para>&power;8</para>
                        </entry>
                        <entry>
                            <para>&power;10</para>
                        </entry>
                        <entry>
                            <para>Runs on &power;9 but this is not supported by &ibm;.
                                &power;9 KVM is not supported.</para>
                        </entry>
                    </row>
                    <row>
                        <entry>
                            <para>&zseries; (s390x)</para>
                        </entry>
                        <entry>
                            <para>z12</para>
                        </entry>
                        <entry>
                            <para>z14</para>
                        </entry>
                        <entry>
                            <para/>
                        </entry>
                    </row>
                    <row>
                        <entry>
                            <para>&arm; (&aarch64;)</para>
                        </entry>
                        <entry>
                            <para>ARMv8.0-A</para>
                        </entry>
                        <entry>
                            <para>ARMv8.0-A</para>
                        </entry>
                        <entry>
                            <para>No change from &slea; 15.</para>
                        </entry>
                    </row>
                    <row>
                        <entry>
                            <para>Intel 32-bit</para>
                        </entry>
                        <entry>
                            <para>Supported</para>
                        </entry>
                        <entry>
                            <para>Not supported</para>
                        </entry>
                        <entry>
                            <para>32-bit system calls are available via
                                <package>grub2-compat-ia32</package> from &suse; Package
                                Hub.</para>
                        </entry>
                    </row>
                </tbody>
            </tgroup>
        </table>
