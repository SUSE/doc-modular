        <title>Desktop environment in &suselinux;&nbsp;16</title><!-- can be changed via merge in the assembly -->
        <!--add author's email address-->
        <meta name="maintainer" content="daria.vladykina@suse.com" its:translate="no"/>
        <!--abstract><!
