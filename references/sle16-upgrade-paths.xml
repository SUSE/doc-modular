   <title>Supported upgrade paths to &productnameshort;&nbsp;&productnumber;</title>
    <!--add author's email address-->
    <meta name="maintainer" content="cwickert@suse.com" its:translate="no"/>
    <abstract><!-- can be changed via merge in the assembly -->
      <para>
       This section lists the upgrade paths for &productname; &productnumber;.
      </para>
    </abstract>
  </info>
  <!--
  <para>
    &productname; &productnumber; allows upgrades from the following products:
  </para>
  -->
  <itemizedlist>
    <title>List of supported upgrade paths</title>
    <listitem os="sles">
      <para>
        &slsa; 15 SP5, SP6, SP7, and 16.0
      </para>
    </listitem>
    <listitem os="sles">
      <para>
        &slerta; 15 SP7 and 16.0
      </para>
    </listitem>
    <listitem os="sles">
      <para>
        &slm; 6.2
      </para>
    </listitem>
    <listitem os="sles">
      <para>
        &leap; 16.1
      </para>
    </listitem>
    <!-- A single listitem looks stupid, list SLES4SAP 15 and 16 separately -->
    <listitem os="sles4sap">
      <para>
        &sles4sapa; 15 SP5, SP6, and SP7
      </para>
    </listitem>
    <listitem os="sles4sap">
      <para>
        &sles4sapa; 16.0
      </para>
    </listitem>
  </itemizedlist>
  <para>
    Other products and versions are not supported. Refer to the documentation of your product to
    upgrade it to a supported version first.
  </para>
</topic>
