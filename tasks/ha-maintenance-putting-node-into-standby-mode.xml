<topic xml:id="ha-maintenance-putting-node-into-standby-mode"
 role="task" xml:lang="en"
 xmlns="http://docbook.org/ns/docbook" version="5.2"
 xmlns:its="http://www.w3.org/2005/11/its"
 xmlns:xi="http://www.w3.org/2001/XInclude"
 xmlns:xlink="http://www.w3.org/1999/xlink"
 xmlns:trans="http://docbook.org/ns/transclusion">
  <info>
    <title>Putting a node into standby mode</title>
    <meta name="maintainer" content="tahlia.richardson@suse.com" its:translate="no"/>
    <abstract>
      <para>
        TODO
      </para>
    </abstract>
  </info>

  <variablelist role="tabs">
    <varlistentry>
      <term>&crmshell;</term>
      <listitem>
        <para>
          Perform this procedure on the node you want to put into standby mode.
        </para>
        <procedure>
          <step>
            <para>
              Log in to the node either as the &rootuser; user or as a user with
              <command>sudo</command> privileges.
            </para>
          </step>
          <step>
            <para>
              Put the node into standby mode:
            </para>
<screen>&prompt.user;<command>sudo crm node standby</command></screen>
            <para>
              TODO In this state, the node can no longer run resources. All resources move to other nodes, unless constraints stop them from doing so. In this case, they stop.
            </para>
          </step>
          <step>
            <para>
              Check the status of the cluster:
            </para>
<screen>&prompt.user;<command>sudo crm status</command></screen>
            <para>
              The node should show the status <literal>standby</literal>.
            </para>
          </step>
        </procedure>
      </listitem>
    </varlistentry>
    <varlistentry>
      <term>&hawk;</term>
      <listitem>
        <!--xi:include href="../snippets/ha-hawk-procedure-intro.xml"/-->
        <procedure>
          <step>
            <para>
              In a Web browser, go to
              <literal>https://<replaceable>HAWKSERVER</replaceable>:7630/</literal> and log in.
            </para>
          </step>
          <step>
            <para>
              In the left navigation bar, select <menuchoice><guimenu>Monitoring</guimenu>
              <guimenu>Status</guimenu></menuchoice>.
            </para>
          </step>
          <step>
            <para>
              Switch to the <guimenu>Nodes</guimenu> tab and find the node you want to put into
              standby mode.
            </para>
          </step>
          <step>
            <para>
              In the <guimenu>Standby</guimenu> column, click the toggle to turn on standby mode.
            </para>
          </step>
          <step>
            <para>
              Click <guimenu>OK</guimenu> to confirm.
            </para>
            <para>
              The toggle changes from green to red.
            </para>
          </step>
        </procedure>
      </listitem>
    </varlistentry>
  </variablelist>
</topic>
