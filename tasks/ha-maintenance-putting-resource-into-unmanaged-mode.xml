<topic xml:id="ha-maintenance-putting-resource-into-unmanaged-mode"
 role="task" xml:lang="en"
 xmlns="http://docbook.org/ns/docbook" version="5.2"
 xmlns:its="http://www.w3.org/2005/11/its"
 xmlns:xi="http://www.w3.org/2001/XInclude"
 xmlns:xlink="http://www.w3.org/1999/xlink"
 xmlns:trans="http://docbook.org/ns/transclusion">
  <info>
    <title>Putting a resource into unmanaged mode</title>
    <meta name="maintainer" content="tahlia.richardson@suse.com" its:translate="no"/>
    <abstract>
      <para>
        TODO
      </para>
    </abstract>
  </info>

  <variablelist role="tabs">
    <varlistentry>
      <term>&crmshell;</term>
      <listitem>
        <!--xi:include href="../snippets/ha-crmsh-procedure-intro.xml"/-->
        <procedure>
          <step>
            <para>
              Log in either as the &rootuser; user or as a user with <command>sudo</command>
              privileges.
            </para>
          </step>
          <step>
            <para>
              Put the node into unmanaged mode:
            </para>
<screen>&prompt.user;<command>sudo crm resource unmanage <replaceable>RESOURCE</replaceable></command></screen>
            <para>
              In this state, the cluster stops managing the resource but continues to monitor it.
            </para>
          </step>
          <step>
            <para>
              Check the status of the cluster:
            </para>
<screen>&prompt.user;<command>sudo crm status</command></screen>
            <para>
              The resource should show the status <literal>unmanaged</literal>.
            </para>
          </step>
        </procedure>
      </listitem>
    </varlistentry>
    <varlistentry>
      <term>&hawk;</term>
      <listitem>
        <!--xi:include href="../snippets/ha-hawk-procedure-intro.xml"/-->
        <procedure>
          <step>
            <para>
              In a Web browser, go to
              <literal>https://<replaceable>HAWKSERVER</replaceable>:7630/</literal> and log in.
            </para>
          </step>
          <step>
            <para>
              In the left navigation bar, select <menuchoice><guimenu>Monitoring</guimenu>
              <guimenu>Status</guimenu></menuchoice>.
            </para>
          </step>
          <step>
            <para>
              Find the resource you want to put into unmanaged mode. In its
              <guimenu>Operations</guimenu> column, click the down arrow icon and select
              <guimenu>Edit</guimenu>.
            </para>
          </step>
          <step>
            <para>
              From the empty drop-down list in the <guimenu>Meta Attributes</guimenu> section,
              select <guimenu>is-managed</guimenu>.
            </para>
            <para>
              A new <guimenu>is-managed</guimenu> drop-down list appears.
            </para>
          </step>
          <step>
            <para>
              From the <guimenu>is-managed</guimenu> drop-down list, select <guimenu>No</guimenu>.
            </para>
          </step>
          <step>
            <para>
              Click <guimenu>Apply</guimenu> to confirm the changes.
            </para>
            <para>
              A message at the top of the screen shows if the action was successful.
            </para>
          </step>
          <step>
            <para>
              In the left navigation bar, select <menuchoice><guimenu>Monitoring</guimenu>
              <guimenu>Status</guimenu></menuchoice>.
            </para>
            <para>
              The resource should be highlighted in yellow and have an <guimenu>Unmanaged</guimenu> icon in the <guimenu>Status</guimenu> column.
            </para>
          </step>
        </procedure>
      </listitem>
    </varlistentry>
  </variablelist>
</topic>
