<topic xml:id="ha-maintenance-starting-cluster-services-whole-cluster"
 role="task" xml:lang="en"
 xmlns="http://docbook.org/ns/docbook" version="5.2"
 xmlns:its="http://www.w3.org/2005/11/its"
 xmlns:xi="http://www.w3.org/2001/XInclude"
 xmlns:xlink="http://www.w3.org/1999/xlink"
 xmlns:trans="http://docbook.org/ns/transclusion">
  <info>
    <title>Starting the cluster services for the whole cluster</title>
    <meta name="maintainer" content="tahlia.richardson@suse.com" its:translate="no"/>
    <abstract>
      <para>
        TODO
      </para>
    </abstract>
  </info>

  <!--xi:include href="../snippets/ha-crmsh-procedure-intro.xml"/-->
  <procedure>
    <step>
      <para>
        Log in either as the &rootuser; user or as a user with <command>sudo</command> privileges.
      </para>
    </step>
    <step>
      <para>
        Start the cluster services again after your maintenance work is done:
      </para>
<screen>&prompt.user;<command>sudo crm cluster start --all</command></screen>
    </step>
    <step>
      <para>
        Check the status of the cluster services:
      </para>
<screen>&prompt.user;<command>sudo crm cluster status</command></screen>
      <para>
        Both &corosync; and &pace; should be <literal>active</literal>.
      </para>
    </step>
    <step>
      <para>
        Check the status of the cluster:
      </para>
<screen>&prompt.user;<command>sudo crm status</command></screen>
      <para>
        The nodes will have the status <literal>UNCLEAN (offline)</literal>, but will soon change
        to <literal>Online</literal>.
      </para>
    </step>
  </procedure>
</topic>
