<!-- refers to legacy doc: https://github.com/SUSE/doc-sleha/blob/main/xml/ha_maintenance.xml -->

<topic xml:id="ha-maintenance-taking-resource-out-of-maintenance-mode"
 role="task" xml:lang="en"
 xmlns="http://docbook.org/ns/docbook" version="5.2"
 xmlns:its="http://www.w3.org/2005/11/its"
 xmlns:xi="http://www.w3.org/2001/XInclude"
 xmlns:xlink="http://www.w3.org/1999/xlink"
 xmlns:trans="http://docbook.org/ns/transclusion">
  <info>
    <title>Taking a resource out of maintenance mode</title>
    <meta name="maintainer" content="tahlia.richardson@suse.com" its:translate="no"/>
    <abstract>
      <para>
        TODO
      </para>
    </abstract>
  </info>

  <variablelist role="tabs">
    <varlistentry>
      <term>&crmshell;</term>
      <listitem>
        <!--xi:include href="../snippets/ha-crmsh-procedure-intro.xml"/-->
        <procedure>
          <step>
            <para>
              Log in either as the &rootuser; user or as a user with <command>sudo</command>
              privileges.
            </para>
          </step>
          <step>
            <para>
              Put the resource back into normal operation:
            </para>
<screen>&prompt.user;<command>sudo crm resource maintenance <replaceable>RESOURCE</replaceable> off</command></screen>
          </step>
          <step>
            <para>
              Check the status of the cluster:
            </para>
<screen>&prompt.user;<command>sudo crm status</command></screen>
            <para>
              The resource should no longer show the status <literal>maintenance</literal>.
            </para>
          </step>
        </procedure>
      </listitem>
    </varlistentry>
    <varlistentry>
      <term>&hawk;</term>
      <listitem>
        <!--xi:include href="../snippets/ha-hawk-procedure-intro.xml"/-->
        <procedure>
          <step>
            <para>
              In a Web browser, go to
              <literal>https://<replaceable>HAWKSERVER</replaceable>:7630/</literal> and log in.
            </para>
          </step>
          <step>
            <para>
              In the left navigation bar, select <menuchoice><guimenu>Monitoring</guimenu>
              <guimenu>Status</guimenu></menuchoice>.
            </para>
          </step>
          <step>
            <para>
              Find the resource you want to take out of maintenance mode.
              In its <guimenu>Operations</guimenu> column, click the
              <guimenu>Disable Maintenance Mode</guimenu> toggle icon.
            </para>
          </step>
          <step>
            <para>
              Click <guimenu>OK</guimenu> to confirm.
            </para>
            <para>
              The resource should now have a green or red <guimenu>Status</guimenu> icon instead
              of a wrench icon.
            </para>
          </step>
        </procedure>
      </listitem>
    </varlistentry>
  </variablelist>
</topic>
